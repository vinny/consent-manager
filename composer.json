{
	"name": "phpbb/consentmanager",
	"type": "phpbb-extension",
	"description": "Centralized GDPR-compliant consent and deferred script loading for phpBB forums.",
	"homepage": "https://www.phpbb.com/",
	"version": "0.3.0-dev",
	"keywords": ["phpbb", "extension", "gdpr", "consent", "cookies"],
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Matt Friedman",
			"role": "Extensions Development Team Lead"
		}
	],
	"require": {
		"php": ">=7.2",
		"composer/installers": "^1.0 || ^2.0",
		"ext-dom": "*"
	},
	"require-dev": {
		"phing/phing": "~2.4"
	},
	"extra": {
		"display-name": "Consent Manager",
		"soft-require": {
			"phpbb/phpbb": ">=3.3.0"
		}
	}
}
